{
	"name": "webguyjeff/error_monitor",
	"description": "Monitor the error log and get notifications about new errors on your WordPress site.",
	"require": {
		"phpmailer/phpmailer": "^6.8"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"wp-coding-standards/wpcs": "^3.0",
		"phpunit/phpunit": "^9.5",
		"yoast/phpunit-polyfills": "^1.0",
		"mockery/mockery": "^1.5"
	},
	"autoload": {
		"psr-4": {
			"WebGuyJeff\\Error_Monitor\\": "classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"WebGuyJeff\\Error_Monitor\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"lint": "vendor/bin/phpcs --standard=phpcs.xml.dist",
		"lint-fix": "vendor/bin/phpcbf --standard=phpcs.xml.dist",
		"lint:changed": "bash ./bin/lint-changed.sh",
		"phpcompat": "./vendor/bin/phpcs -p . --standard=PHPCompatibilityWP --extensions=php --runtime-set testVersion 5.6-",
		"test": "phpunit",
		"test:unit": "phpunit --testsuite unit",
		"test:integration": "phpunit --testsuite integration"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
